# ═══════════════════════════════════════════════════════════════
# .gitignore — LDA Image Classification Research Project
# ═══════════════════════════════════════════════════════════════
# Only active code, results CSVs, paper source, and config are tracked.
# Everything else is generated, cached, or archived locally.

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ── Virtual Environments ──
venv/
.venv/
env/
.env/

# ── Datasets (large, auto-downloaded) ──
data/cifar-100-python/
data/cifar-100-python.tar.gz
data/tiny-imagenet-200/
data/CUB_200_2011/
data/CUB_200_2011.tgz
data/*.npz

# ── Cached Features (large .npz/.npy files, regenerated) ──
features/saved/
features/tiny_imagenet/
features/cub200/

# ── Archive (deprecated code, kept locally only) ──
archive/

# ── ArXiv Submission (build artifact, regenerate from paper/) ──
arxiv_submission/
arxiv_submission.zip

# ── Paper Build Artifacts (regenerated via pdflatex) ──
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.fls
paper/*.fdb_latexmk
paper/*.synctex.gz
paper/*.toc
paper/main.pdf
paper/figures/*.png

# ── Logs ──
*.log
*_log.txt

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
Thumbs.db

# ── Jupyter ──
.ipynb_checkpoints/

# ── Git Artifacts ──
.git 2/

# ── Workspace-specific (not for public repo) ──
.github/
docs/
progress.md
